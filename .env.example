# ============================================================
# SLINGSHOT v1.0 — Variables de Entorno (PLANTILLA)
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a git — ya está en .gitignore.
# ============================================================

# 🌐 FRONTEND → BACKEND
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000
# Producción:
# NEXT_PUBLIC_API_URL=https://slingshot-engine.onrender.com
# NEXT_PUBLIC_API_WS_URL=wss://slingshot-engine.onrender.com

# 📡 BINANCE API
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 🔮 GEMINI AI (LLM Advisor)
GEMINI_API_KEY=

# 📰 DATOS FANTASMA
CRYPTOPANIC_API_KEY=

# 💾 SUPABASE — Solo usado por Next.js frontend (no por el engine Python)
SUPABASE_URL=
SUPABASE_KEY=

# 🧠 ML & CACHE
REDIS_URL=redis://localhost:6379
MODEL_DIR=./engine/ml/models

# 💰 GESTIÓN DE RIESGO
ACCOUNT_BALANCE=1000.0
MAX_RISK_PCT=0.01
MIN_RR=3.0

# 💬 TELEGRAM BOT
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
