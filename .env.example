# ============================================================
# SLINGSHOT v6.0.1 — Variables de Entorno (PLANTILLA)
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a git — ya está en .gitignore.
# ============================================================

# 🌐 FRONTEND → BACKEND
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000
# Producción (Render):
# NEXT_PUBLIC_API_URL=https://slingshot-engine.onrender.com
# NEXT_PUBLIC_API_WS_URL=wss://slingshot-engine.onrender.com

# 📡 BINANCE API
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 🧠 OLLAMA — LLM LOCAL (Advisor Táctico)
# Modelo activo: qwen3:8b (recomendado — mejor JSON y razonamiento financiero)
# Alternativa rápida: gemma3:4b (si VRAM < 6 GB)
OLLAMA_MODEL=qwen3:8b
OLLAMA_URL=http://localhost:11434

# 🔮 GEMINI AI (reservado para futuras features — no activo en v6.0)
GEMINI_API_KEY=

# 📰 DATOS FANTASMA
CRYPTOPANIC_API_KEY=

# 💤 SUPABASE — Reservado para Roadmap P3 (persistencia histórica de señales)
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 🧠 ML
MODEL_DIR=./engine/ml/models
# REDIS_URL=redis://localhost:6379  # 💤 DESACTIVADO en v3.3 — sistema 100% Local-First

# 💰 GESTIÓN DE RIESGO
ACCOUNT_BALANCE=1000.0
MAX_RISK_PCT=0.01
MIN_RR=2.5  # Unificado con config.py (era 3.0 en .env.example, 1.8 en .env — corregido v6.0.1)

# 💬 TELEGRAM BOT
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
